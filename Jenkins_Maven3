# Set Maven path
export PATH=$PATH:/home/oracle/tools/maven/apache-maven-3.9.12/bin

# Step 1: Go to oracle home
cd /var/lib/jenkins/workspace/Maven1-demo

# Step 2: Create project folder
mkdir -p demo-project
cd demo-project

# Step 3: Generate Maven web project
mvn archetype:generate \
  -DgroupId=com.demo \
  -DartifactId=myapp \
  -DarchetypeArtifactId=maven-archetype-webapp \
  -DinteractiveMode=false

# Step 4: Enter project
cd myapp

# Step 5: Build
mvn clean install

# Step 6: Check WAR
ls target/

# Step 7: Deploy to Tomcat
cp target/*.war /home/oracle/tools/apache-tomcat-9.0.115/webapps/

echo "Deployment Successful 🚀"
